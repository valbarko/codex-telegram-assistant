TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
# Optional comma-separated IDs that may only transcribe voice and audio. Their content is not persisted.
TELEGRAM_TRANSCRIPTION_ONLY_USER_IDS=

ASSISTANT_WORKSPACE=
ASSISTANT_DATA_DIR=
# Readable Markdown backup for diary and story voice modes.
WRITING_ARCHIVE_DIR=
# Local MemSearch CLI. Defaults to ~/.local/bin/memsearch.
MEMSEARCH_BIN=

# Example: {"trenervkarmane":"ТРЕНЕР","clients":"КЛИЕНТЫ","money":"ДЕНЬГИ"}
PROJECT_ALIASES_JSON={}

# Morning weather. Defaults to Moscow.
WEATHER_LOCATION=Москва
WEATHER_LATITUDE=55.7558
WEATHER_LONGITUDE=37.6173

ASSISTANT_DEFAULT_PROFILE=default
CODEX_MODEL=
MAX_UPLOAD_BYTES=20971520
SHOW_TURN_USAGE=false

# Optional local MLX Whisper environment.
WHISPER_PYTHON=python3
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# Name of a local Shortcut whose Clock action creates an alarm from Shortcut Input.
ALARM_SHORTCUT_NAME=Codex Alarm
