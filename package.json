{
  "name": "codex-telegram-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Independent Telegram client and personal assistant for Codex app-server",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "migrate": "tsx src/migrate-user-data.ts",
    "style:build": "node scripts/build-style-corpus.mjs",
    "style:index": "memsearch index .private/style-corpus/posts --collection cta_style_valentin --provider onnx --description 'Private writing corpus for Valentin Barko' --force",
    "style:search": "memsearch search --top-k 8 --collection cta_style_valentin --provider onnx",
    "style:search:personal": "memsearch search --top-k 8 --collection cta_style_valentin --provider onnx --source-prefix \"$PWD/.private/style-corpus/posts/barko-pro-zhizn\"",
    "style:search:expert": "memsearch search --top-k 8 --collection cta_style_valentin --provider onnx --source-prefix \"$PWD/.private/style-corpus/posts/v-svoem-tele\""
  },
  "dependencies": {
    "@grammyjs/auto-retry": "2.0.2",
    "better-sqlite3": "12.11.1",
    "grammy": "1.38.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.3.0",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "vitest": "3.2.7"
  }
}
